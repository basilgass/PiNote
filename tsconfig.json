{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "types": [
            "node", "vite/client"
        ],
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@core/*": [
                "src/core/*"
            ],
            "@pi-vue/*": [
                "src/vue/*"
            ]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue", "dev/**/*.vue"]
}